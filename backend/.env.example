# RPC endpoint of the network the contract is deployed to.
# Sepolia example (Alchemy / Infura / public):
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Private key of the account used to send mint/burn transactions.
# For mint to work this MUST be the contract owner (the deployer).
# 0x-prefixed, 64 hex chars. NEVER commit a real key.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Address of the deployed TestToken contract.
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Port the HTTP server listens on.
PORT=3000
